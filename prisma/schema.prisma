generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlserver"
}

model Sede {
  id              Int            @id @default(autoincrement())
  nombre          String
  direccion       String?
  talleres        Taller[]
  alumnosSige     AlumnoSige[]
  usuariosLocales UsuarioLocal[]
}

model Taller {
  id               Int              @id @default(autoincrement())
  nombre           String
  descripcion      String?          @db.VarChar(500)
  edadMinima       Int
  edadMaxima       Int
  horarios         HorarioTaller[]
  cuposTotales     Int
  cuposDisponibles Int
  sedeId           Int
  sede             Sede             @relation(fields: [sedeId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  inscripciones    Inscripcion[]
  profesores       ProfesorTaller[]
  asistencias      Asistencia[]
  listaEspera      ListaEspera[]    @relation("TallerEnEspera")
}

model HorarioTaller {
  id           Int    @id @default(autoincrement())
  tallerId     Int
  taller       Taller @relation(fields: [tallerId], references: [id], onDelete: Cascade)
  diaSemana    String
  horaInicio   Int
  minutoInicio Int
  horaFin      Int
  minutoFin    Int
}

model Apoderado {
  id            Int           @id @default(autoincrement())
  rut           String        @unique
  nombre        String
  telefono      String
  email         String        @unique
  password      String
  alumnos       Alumno[]
  listaEspera   ListaEspera[] @relation("ApoderadoEnEspera")
  createdAt     DateTime      @default(now())
}

model Establecimiento {
  id      Int      @id @default(autoincrement())
  nombre  String   @unique
  alumnos Alumno[]
}

model CursoAlumno {
  id         Int      @id @default(autoincrement())
  descGrado  String
  letraCurso String
  alumnos    Alumno[]

  @@unique([descGrado, letraCurso])
}

model Alumno {
  id                Int              @id @default(autoincrement())
  rut               String           @unique
  nombres           String
  apellidos         String
  fechaNacimiento   DateTime
  curso             String?
  apoderadoId       Int
  apoderado         Apoderado        @relation(fields: [apoderadoId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  establecimientoId Int?
  establecimiento   Establecimiento? @relation(fields: [establecimientoId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  cursoAlumnoId     Int?
  cursoAlumno       CursoAlumno?     @relation(fields: [cursoAlumnoId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  inscripciones     Inscripcion[]
  createdAt         DateTime         @default(now())
  asistencias       Asistencia[]
  listaEspera       ListaEspera[]    @relation("AlumnoEnEspera")
}

model Inscripcion {
  id          Int      @id @default(autoincrement())
  fecha       DateTime @default(now())
  
  alumnoId    Int
  alumno      Alumno   @relation(fields: [alumnoId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  
  tallerId    Int
  taller      Taller   @relation(fields: [tallerId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  
  // Apoderado eliminado de aquí para evitar redundancia y ciclos
  
  parentesco     String? @db.VarChar(100)
  parentescoOtro String? @db.VarChar(100)

  enfermedadCronica            Boolean @default(false)
  enfermedadCronicaDetalle     String? @db.VarChar(1000)
  tratamientoMedico            String? @db.VarChar(1000)
  alergias                     String? @db.VarChar(1000)
  necesidadesEspeciales        Boolean @default(false)
  necesidadesEspecialesDetalle String? @db.VarChar(1000)
  apoyoEscolar                 String? @db.VarChar(1000)
  usoImagen                    Boolean @default(false)

  @@unique([alumnoId, tallerId])
}

model UsuarioLocal {
  id         Int    @id @default(autoincrement())
  email      String @unique
  nombre     String
  externalId Int?   @unique
  rol        String @default("PROFESOR")
  sedeId     Int?
  sede       Sede?  @relation(fields: [sedeId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  isActive   Boolean @default(true)
  createdAt  DateTime @default(now())
  talleres   ProfesorTaller[]
}

model ProfesorTaller {
  id        Int          @id @default(autoincrement())
  usuarioId Int
  usuario   UsuarioLocal @relation(fields: [usuarioId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  tallerId  Int
  taller    Taller       @relation(fields: [tallerId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@unique([usuarioId, tallerId])
}

model Asistencia {
  id            Int      @id @default(autoincrement())
  fecha         DateTime
  estado        String
  alumnoId      Int
  alumno        Alumno   @relation(fields: [alumnoId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  tallerId      Int
  taller        Taller   @relation(fields: [tallerId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  registradoPor Int
  createdAt     DateTime @default(now())

  @@unique([tallerId, alumnoId, fecha])
}

model AlumnoSige {
  id                   Int      @id @default(autoincrement())
  sedeId               Int
  sede                 Sede     @relation(fields: [sedeId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  anio                 Int?
  rbd                  Int?
  codTipoEnsenanza     Int?
  codGrado             Int?
  descGrado            String?
  letraCurso           String?
  run                  String?
  dv                   String?
  genero               String?
  nombres              String?
  apellidoPaterno      String?
  apellidoMaterno      String?
  direccion            String?
  comunaResidencia     String?
  codigoComuna         String?
  email                String?
  telefono             String?
  celular              String?
  fechaNacimiento      String?
  codigoEtnia          String?
  fechaIncorporacion   String?
  fechaRetiro          String?
  porcentajeAsistencia Float?
  promedioFinal        Float?
  runc                 String
  nombrec              String
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  @@unique([runc, anio, sedeId])
}

model ListaEspera {
  id             Int      @id @default(autoincrement())
  alumnoId       Int
  tallerId       Int
  apoderadoId    Int      @default(0) // Vinculamos directamente al apoderado para trazabilidad
  posicion       Int      @default(0)
  parentesco     String?
  parentescoOtro String?
  
  // Guardamos la ficha completa para no perderla si pasa a inscripción real
  enfermedadCronica            Boolean @default(false)
  enfermedadCronicaDetalle     String? @db.VarChar(1000)
  tratamientoMedico            String? @db.VarChar(1000)
  alergias                     String? @db.VarChar(1000)
  necesidadesEspeciales        Boolean @default(false)
  necesidadesEspecialesDetalle String? @db.VarChar(1000)
  apoyoEscolar                 String? @db.VarChar(1000)
  usoImagen                    Boolean @default(false)

  fecha          DateTime @default(now())
  alumno         Alumno   @relation("AlumnoEnEspera", fields: [alumnoId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  taller         Taller   @relation("TallerEnEspera", fields: [tallerId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  apoderado      Apoderado @relation("ApoderadoEnEspera", fields: [apoderadoId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@unique([alumnoId, tallerId])
}
